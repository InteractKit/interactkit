<?xml version="1.0" encoding="UTF-8"?>
<graph xmlns="https://interactkit.dev/schema/v1" version="1" root="Agent">
  <entity name="Agent" type="base" description="Agent with memory component">
    <describe>Agent</describe>
    <components>
      <component name="memory" entity="Memory" />
    </components>
  </entity>
  <entity name="Memory" type="base" description="Memory store">
    <describe>Memory</describe>
    <state>
      <field name="entries" type="array" description="Entries" items="string" />
    </state>
    <tools>
      <tool name="store" description="Store">
        <input><param name="text" type="string" /></input>
        <output type="number" />
      </tool>
    </tools>
  </entity>
</graph>
