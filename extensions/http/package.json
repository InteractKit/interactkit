{
  "name": "@interactkit/http",
  "version": "0.2.4",
  "description": "HTTP webhook extension for InteractKit — receive and send HTTP requests",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "interactkit",
    "extension",
    "http",
    "webhook"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@interactkit/sdk": "^0.2.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@interactkit/sdk": "workspace:*",
    "@types/node": "^25.5.0",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.5.0"
  }
}
