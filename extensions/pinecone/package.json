    "@pinecone-database/pinecone": "^4.0.0"
  },
  "devDependencies": {
    "@interactkit/sdk": "workspace:*",
    "@pinecone-database/pinecone": "^4.0.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.5.0"
  }
