{
  "name": "@interactkit/cron",
  "version": "0.2.1",
  "description": "Cron scheduling extension for InteractKit — trigger hooks on cron schedules using node-cron",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "interactkit",
    "extension",
    "cron",
    "scheduler"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "node-cron": "^3.0.3"
  },
  "peerDependencies": {
    "@interactkit/sdk": "^0.2.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@interactkit/sdk": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.5.0"
  }
}
