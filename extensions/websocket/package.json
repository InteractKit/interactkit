{
  "name": "@interactkit/websocket",
  "version": "0.2.0",
  "description": "WebSocket extension for InteractKit — bidirectional real-time messaging",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "interactkit",
    "extension",
    "websocket",
    "realtime"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@interactkit/sdk": "^0.2.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@interactkit/sdk": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.0",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.5.0"
  }
}
